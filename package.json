{
  "name": "contexts-mcp",
  "version": "1.0.0",
  "description": "Local MCP server for managing markdown context files across Claude Code sessions",
  "type": "module",
  "bin": {
    "contexts-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "ui": "node dist/web.js",
    "install:shortcut": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/node": "^22",
    "typescript": "^5.8.2"
  }
}
